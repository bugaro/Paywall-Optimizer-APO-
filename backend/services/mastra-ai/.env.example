# Mastra AI Service Configuration

# Port the service listens on
PORT=4006

# Node environment (development, production, test)
NODE_ENV=development

# Database connection string for RAG vector store
DATABASE_URL=postgres://postgres:password@localhost:5437/mastra_memory

# URL of the running Ollama instance
OLLAMA_URL=http://localhost:11434

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# OpenTelemetry OTLP/gRPC collector endpoint (e.g. Grafana Alloy)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name resource attribute for OpenTelemetry traces
SERVICE_NAME=mastra-ai
