# Telemetry & Analytics Standalone Local Environment Configuration

# Database Connection (Note: Default Docker Compose Postgres port is mapped to 5436)
DATABASE_URL=postgres://postgres:password@localhost:5436/apo_telemetry

# Service Port
TELEMETRY_ANALYTICS_PORT=4003
PORT=4003

# Traffic Simulator Action Tick Interval (ms)
TICK_INTERVAL_MS=100

# Environment Mode
NODE_ENV=development
