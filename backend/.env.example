# Master Environment Configuration Template

# Database Configuration
DATABASE_PORT=5436
DATABASE_NAME=apo_telemetry
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# Telemetry & Analytics Microservice Configuration
TELEMETRY_ANALYTICS_PORT=4003
TICK_INTERVAL_MS=100

# Copilot Bridge Microservice Configuration
COPILOT_BRIDGE_PORT=4005

# Mastra AI Service Configuration
MASTRA_AI_PORT=4006
OLLAMA_URL=http://localhost:11434
DATABASE_URL_MASTRA=postgres://postgres:password@localhost:5437/mastra_memory

# OpenTelemetry Configuration (mastra-ai → Grafana Alloy)
# Set to the Alloy OTLP gRPC endpoint. Use http://alloy:4317 inside Docker Compose
# and http://localhost:4317 for local development without Docker.
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
LOG_LEVEL=info

# Copilot Agent Configuration
COPILOT_AGENT_PROVIDER=ollama
COPILOT_AGENT_MODEL=qwen2.5:3b
MASTRA_AI_URL=http://localhost:4006
